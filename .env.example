# Copy to .env and fill in real secrets locally.
# Do not commit real API keys, private corpus files, generated indexes, or traces.

# AI provider credentials
# Required for hosted Qwen answer generation, embeddings, vector indexing, OCR, and reranking.
DASHSCOPE_API_KEY=

# DashScope endpoints.
# Beijing defaults:
IMPERIAL_RAG_DASHSCOPE_REGION=beijing
IMPERIAL_RAG_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
IMPERIAL_RAG_DASHSCOPE_COMPAT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Hosted Qwen models.
IMPERIAL_RAG_QWEN_CHAT_MODEL=qwen3.7-plus
IMPERIAL_RAG_QWEN_VISION_MODEL=qwen-vl-ocr-2025-11-20
IMPERIAL_RAG_QWEN_OCR_TASK=multi_lan
IMPERIAL_RAG_QWEN_OCR_MIN_PIXELS=
IMPERIAL_RAG_QWEN_OCR_MAX_PIXELS=
IMPERIAL_RAG_QWEN_OCR_ENABLE_ROTATE=
IMPERIAL_RAG_QWEN_EMBEDDING_MODEL=text-embedding-v4
IMPERIAL_RAG_QWEN_EMBEDDING_DIMENSIONS=2048
IMPERIAL_RAG_QWEN_RERANK_MODEL=qwen3-rerank

# Legacy provider escape hatches for debugging only.
IMPERIAL_RAG_ALLOW_LEGACY_OPENAI=false
IMPERIAL_RAG_ALLOW_LEGACY_COHERE=false
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
COHERE_API_KEY=

# Local workspace
IMPERIAL_RAG_WORKSPACE_ROOT=/Users/danil/Public/imperial

# Qdrant vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=imperial_chunks_qwen

# Elasticsearch keyword search
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=imperial_keyword_chunks

# Set to 1 only when intentionally running paid/network DashScope smoke and integration tests.
IMPERIAL_RAG_LIVE_API=0

# Set to 1 only when intentionally testing the existing generated `.imperial_rag` corpus state.
IMPERIAL_RAG_LIVE_CORPUS=0

# Optional path to a trusted env file when running live tests from an isolated worktree.
IMPERIAL_RAG_LIVE_ENV_PATH=

# Set to 1 only when intentionally running live Qdrant tests.
IMPERIAL_RAG_LIVE_QDRANT=0

# Set to 1 only when intentionally running live Elasticsearch tests.
IMPERIAL_RAG_LIVE_ELASTICSEARCH=0

# Phoenix tracing and eval storage
PHOENIX_PROJECT_NAME=imperial-rag
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_CLIENT_ENDPOINT=http://localhost:6006
PHOENIX_TRACING_ENABLED=false
IMPERIAL_RAG_TRACING_ENABLED=false

# Compose container overrides
# compose.yaml sets these inside app and ingest containers so host-local commands can keep localhost defaults above.
# IMPERIAL_RAG_WORKSPACE_ROOT=/app
# ELASTICSEARCH_URL=http://elasticsearch:9200
# QDRANT_URL=http://qdrant:6333
# PHOENIX_CLIENT_ENDPOINT=http://phoenix:6006
# PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006/v1/traces

# Local structured logs
IMPERIAL_RAG_LOG_LEVEL=INFO
IMPERIAL_RAG_LOG_FORMAT=json

# Retrieval and chunking tuning
IMPERIAL_RAG_CHUNK_SIZE=400
IMPERIAL_RAG_CHUNK_OVERLAP=50
IMPERIAL_RAG_VECTOR_FETCH_K=70
IMPERIAL_RAG_VECTOR_K=70
IMPERIAL_RAG_KEYWORD_LIMIT=30
IMPERIAL_RAG_RERANK_INPUT_LIMIT=100
IMPERIAL_RAG_RERANK_TOP_N=10
IMPERIAL_RAG_MMR_LAMBDA_MULT=0.4
IMPERIAL_RAG_PRIMARY_RERANKER=dashscope:qwen3-rerank
IMPERIAL_RAG_FALLBACK_RERANKER=fallback:deterministic
